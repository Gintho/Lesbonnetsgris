{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bonnets-gris/cta",
	"title": "CTA",
	"category": "bonnets-gris",
	"icon": "megaphone",
	"description": "Bloc d'appel à l'action (étiquette, titre, description, CTA), fond couleur ou média, réutilisable sur tout le site.",
	"textdomain": "bonnets-gris",
	"attributes": {
		"layout": {
			"type": "string",
			"default": "horizontal",
			"enum": [ "horizontal", "bande-photo", "centre" ]
		},
		"reverse": {
			"type": "boolean",
			"default": false
		},
		"backgroundType": {
			"type": "string",
			"default": "couleur",
			"enum": [ "couleur", "media" ]
		},
		"tone": {
			"type": "string",
			"default": "nude"
		},
		"mediaId": {
			"type": "number",
			"default": 0
		},
		"mediaUrl": {
			"type": "string",
			"default": ""
		},
		"eyebrow": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"ctaLabel": {
			"type": "string",
			"default": ""
		},
		"ctaUrl": {
			"type": "string",
			"default": "#"
		},
		"ctaTarget": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
