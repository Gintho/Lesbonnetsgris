{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "bonnets-gris/carte-soutien",
  "title": "Carte de soutien",
  "category": "bonnets-gris",
  "icon": "heart",
  "description": "Une carte \"comment nous soutenir\" (titre, sous-titre, description, CTA).",
  "textdomain": "bonnets-gris",
  "attributes": {
    "tone": {
      "type": "string",
      "default": "nude",
      "enum": [
        "nude",
        "sky",
        "orange",
        "terracotta"
      ]
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "ctaLabel": {
      "type": "string",
      "default": ""
    },
    "ctaUrl": {
      "type": "string",
      "default": "#"
    }
  },
  "supports": {
    "html": false
  },
  "editorScript": "file:./index.js"
}