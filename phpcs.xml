<?xml version="1.0"?>
<ruleset name="BonnetsGris">
	<description>Ruleset WPCS pour le thème Les Bonnets Gris.</description>

	<file>.</file>
	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<!-- Compiled block assets: regenerated by `npm run build`, not hand-authored. -->
	<exclude-pattern>/build/*</exclude-pattern>

	<arg value="sp"/>
	<arg name="basepath" value="."/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>

	<rule ref="WordPress-Core"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="bonnets-gris"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="bonnets_gris"/>
			</property>
		</properties>
		<!--
		Template-part and template files are always include()'d by WordPress
		into a controlled local scope (never invoked as standalone globals),
		so their local variables ($args-derived: $text, $tone, etc.) are not
		global namespace pollution. Applying this sniff there is pure noise —
		it only makes sense for functions.php/inc/*.php, where every
		bonnets_gris_* function/hook is already correctly prefixed.
		-->
		<exclude-pattern>*/template-parts/*</exclude-pattern>
		<exclude-pattern>*/page-templates/*</exclude-pattern>
		<exclude-pattern>^front-page\.php$</exclude-pattern>
		<exclude-pattern>^index\.php$</exclude-pattern>
		<exclude-pattern>^header\.php$</exclude-pattern>
		<exclude-pattern>^footer\.php$</exclude-pattern>
		<!-- Same reasoning for block render.php files: WordPress include()'s
		     them into a controlled local scope ($attributes/$content/$block). -->
		<exclude-pattern>*/src/*/render\.php$</exclude-pattern>
	</rule>
</ruleset>
